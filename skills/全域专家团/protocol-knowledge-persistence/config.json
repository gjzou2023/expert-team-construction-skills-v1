{
  "id": "protocol-knowledge-persistence",
  "layer": "L2",
  "name_zh": "知识资产沉淀协议",
  "name_en": "Knowledge Persistence Protocol",
  "version": "1.1.0",
  "description": "设计决策沉淀到§5.5，执行细节沉淀到§7.3，多模态资产管理(参数快照)。版本迁移指南。",
  "trigger_keywords": [
    "知识沉淀",
    "保存",
    "版本",
    "参数快照",
    "多模态资产"
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "decision_type": {
        "type": "string",
        "enum": [
          "design",
          "execution",
          "parameter_change"
        ]
      },
      "content": {
        "type": "object"
      },
      "metadata": {
        "type": "object",
        "properties": {
          "stage": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        }
      }
    },
    "required": [
      "decision_type",
      "content",
      "metadata"
    ]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "persisted": {
        "type": "boolean"
      },
      "storage_location": {
        "type": "string",
        "enum": [
          "section_5.5",
          "section_7.3"
        ]
      },
      "asset_type": {
        "type": "string",
        "enum": [
          "text",
          "config",
          "parameter_snapshot",
          "multimodal"
        ]
      },
      "version": {
        "type": "string"
      }
    },
    "required": [
      "persisted",
      "storage_location",
      "asset_type",
      "version"
    ]
  },
  "tool_declarations": [],
  "few_shot_examples": [
    {
      "name": "正常流程",
      "input": {
        "user_input": "小红书内容团队要从选题到发布形成稳定流程",
        "context": {
          "domain_type": "A",
          "platform": "workbuddy"
        }
      },
      "output": {
        "status": "completed",
        "decision": "知识资产沉淀协议已按A型内容传播场景执行",
        "next_action": "进入下一阶段或触发质量门控"
      }
    },
    {
      "name": "边界/异常",
      "input": {
        "user_input": "我们做医疗科普，但想尽量直接承诺效果",
        "context": {
          "domain_type": "A",
          "regulated": true
        }
      },
      "output": {
        "status": "blocked_or_review",
        "risk": "强监管合规风险",
        "required_call": "protocol-compliance-engine"
      }
    },
    {
      "name": "快速通道变体",
      "input": {
        "user_input": "只有我一个人，先要一个能用的提示词版客服助手",
        "context": {
          "role_count": 1,
          "deliverable_count": 2,
          "channel": "fast"
        }
      },
      "output": {
        "status": "simplified",
        "strategy": "保留核心交付物与兜底方案，跳过或内联低风险阶段"
      }
    }
  ],
  "knowledge_base_mount_points": [
    {
      "type": "static",
      "path": "file://knowledge-persistence/multimodal-template",
      "description": "多模态资产参数快照模板"
    },
    {
      "type": "dynamic",
      "path": "file://runtime/protocol-knowledge-persistence/state",
      "description": "运行时状态、用户确认和阶段快照"
    },
    {
      "type": "rag",
      "path": "file://rag/protocol-knowledge-persistence/references",
      "description": "向量检索：源文档、平台规则和历史案例"
    }
  ],
  "dependencies": [
    "core-mental-model-engine"
  ],
  "execution_logic": "(1)设计决策沉淀到§5.5:架构决策、角色定义、SOP设计依据→(2)执行细节沉淀到§7.3:工具配置、提示词、数据映射→(3)多模态资产管理:参数快照(生成参数+模型版本+种子值+提示词)→(4)版本迁移指南。多模态资产(5.5修订)：AI生成的图片/视频/音频:必须保存生成参数(模型版本+种子值+提示词+参数),而非仅保存产出文件。",
  "cascading_calls": [
    "core-mental-model-engine"
  ],
  "context_inheritance": [
    "current_stage_outputs",
    "domain_type"
  ],
  "shared_memory_keys": [
    "protocol-knowledge-persistence_state"
  ],
  "protocol": {
    "cascading_enabled": true,
    "context_inheritance_enabled": true,
    "shared_memory_enabled": true,
    "cascade_direction": "同层或下层可调用",
    "data_passing_format": "JSON-compatible",
    "immutability_rule": "上游产出一经确认，下游不得擅自修改，需通过回退协议",
    "traceability": "每个字段标注来源阶段和Skill",
    "mandatory_calls": [
      {
        "trigger": "before_output",
        "call": "self.execute_10_checks",
        "timing": "before_output"
      },
      {
        "callee": "protocol-quality-gate",
        "when": "阶段结束或产出方案前",
        "reason": "Doc1 CROSS_SKILL_PROTOCOL: ANY_SKILL -> SK-001"
      }
    ]
  },
  "compatibility": {
    "min_compatible": "1.1.0",
    "breaking_change": "2.0.0"
  },
  "priority": 2
}
